{% if page.pdf %}
<div class="pdf-embed-container mt-4 mb-2">
  <iframe
    src="{{ page.pdf | prepend: '/assets/pdf/' | relative_url }}"
    width="100%"
    height="750px"
    style="border: 1px solid var(--global-divider-color, #ddd); border-radius: 6px; display: block;"
    title="{{ page.title }} — PDF"
  >
    <p>
      Your browser does not support embedded PDFs.
      <a href="{{ page.pdf | prepend: '/assets/pdf/' | relative_url }}" target="_blank">Download the PDF</a> instead.
    </p>
  </iframe>
  <div class="mt-2 text-center">
    <a href="{{ page.pdf | prepend: '/assets/pdf/' | relative_url }}" class="btn btn-sm z-depth-0" role="button" target="_blank">
      <i class="fas fa-file-pdf"></i> Download PDF
    </a>
  </div>
</div>
{% endif %}
