<div class="selected-projects">
  {% assign selected = site.projects | where: "selected", true | sort: "importance" %}
  {% for project in selected %}
    <div class="col mb-2 px-0">
      <a href="{% if project.redirect %}{{ project.redirect }}{% else %}{{ project.url | relative_url }}{% endif %}">
        <div class="card hoverable selected-project-card">
          <div class="row no-gutters align-items-center">
            {% if project.img %}
              <div class="col-md-3">
                {% include figure.liquid loading="eager" path=project.img sizes="120px" alt="project thumbnail" class="card-img selected-project-img" %}
              </div>
            {% endif %}
            <div class="{% if project.img %}col-md-9{% else %}col-md-12{% endif %}">
              <div class="card-body py-2 px-3">
                <h3 class="card-title mb-1">{{ project.title }}</h3>
                <p class="card-text small mb-0">{{ project.description }}</p>
              </div>
            </div>
          </div>
        </div>
      </a>
    </div>
  {% endfor %}
</div>
